{
  "name": "martian-lsp",
  "displayName": "Martian (MRO)",
  "description": "Language server client for the Martian (.mro) pipeline language.",
  "version": "0.1.3",
  "publisher": "eunmann",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eunmann/martian-lsp"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mro"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mro",
        "aliases": [
          "Martian",
          "mro"
        ],
        "extensions": [
          ".mro"
        ],
        "filenames": [
          "_invocation",
          "_mrosource"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mro",
        "scopeName": "source.mro",
        "path": "./syntaxes/mro.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Martian",
      "properties": {
        "martian.serverPath": {
          "type": "string",
          "default": "mrlsp",
          "description": "Path to the mrlsp language server binary."
        },
        "martian.mroPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra MRO include search directories. Relative paths (e.g. \"mro\") are resolved against the workspace root. The nearest ancestor \"mro\" directory and the $MROPATH environment variable are also searched automatically."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "tsc -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
